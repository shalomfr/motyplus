# iCount Integration Environment Variables

# iCount API Configuration
# Company ID - found in iCount account settings
ICOUNT_COMPANY_ID=12345

# iCount User Credentials (for username/password auth)
# Format: username|||password
ICOUNT_CREDENTIALS=user@example.com|||MyPassword123

# OR use API Token (Bearer token auth)
# Format: API_TOKEN_HERE
# ICOUNT_API_TOKEN=API_TOKEN_HERE

# Webhook Security Secret
# Used to verify incoming webhooks from iCount
# Generate a strong random string
ICOUNT_WEBHOOK_SECRET=your-secret-webhook-token-here

# iCount Webhook URLs (configure these in iCount settings)
# Document Webhook (Section 22): https://yourdomain.com/api/webhooks/icount
# Payment Page Webhook (Section 22א): https://yourdomain.com/api/webhooks/icount

# iCount Settings (JSON, optional)
# ICOUNT_SETTINGS={"defaultLanguage":"he","autoSendEmail":true,"vatExempt":false}
